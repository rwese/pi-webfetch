{
  "name": "pi-webfetch",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "pi": {
    "extensions": ["./extensions"]
  },
  "scripts": {
    "clean": "rm -rf dist coverage",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "ci": "npm run check && npm run test:coverage"
  },
  "dependencies": {
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "latest",
    "@sinclair/typebox": "latest",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.8.9",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  }
}
